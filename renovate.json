{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":disableDependencyDashboard"
  ],
  "configMigration": true,
  "semanticCommits": "enabled",
  "automerge": false,
  "mode": "full",
  "enabledManagers": [
    "custom.regex",
    "kustomize"
  ],
  "argocd": {
    "managerFilePatterns": [
      "**/*-application.yaml",
      "**/application.yaml"
    ]
  },
  "customManagers": [
    {
      "description": "GitHub inline links that use ?ref=<tag>",
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.ya?ml$/"
      ],
      "matchStrings": [
        "github\\.com/(?<depName>[^/]+/[^/]+)/.*\\?ref=(?<currentValue>v?[0-9.]+)"
      ],
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "Inline comment to track dependency",
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.ya?ml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) registryUrl=(?<registryUrl>\\S+) depName=(?<depName>\\S+)\\s+version: (?<currentValue>.*)"
      ]
    },
    {
      "description": "Manage talos version in talhelper TODO: update to what we're using in talosctl",
      "customType": "regex",
      "managerFilePatterns": [
        "/talconfig\\.yaml$/"
      ],
      "matchStrings": [
        "talosVersion:\\s*[\"\\\"]?(?<currentValue>v[0-9.]+)[\"\\\"]?"
      ],
      "depNameTemplate": "siderolabs/talos",
      "datasourceTemplate": "github-releases"
    },
    {
      "description": "Manage k8s version in talhelper TODO: upate to what we're usiing in talosctl",
      "customType": "regex",
      "managerFilePatterns": [
        "/talconfig\\.yaml$/"
      ],
      "matchStrings": [
        "kubernetesVersion:\\s*[\"\\\"]?(?<currentValue>v[0-9.]+)[\"\\\"]?"
      ],
      "depNameTemplate": "kubernetes/kubernetes",
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "kubernetes"
    }
  ]
}
